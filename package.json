{
  "name": "novoriq-revenue-os",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace @novoriq/api\" \"npm run dev --workspace @novoriq/web\"",
    "build": "npm run build --workspace @novoriq/api && npm run build --workspace @novoriq/web",
    "lint": "eslint .",
    "test": "node tests/run.js",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "eslint": "^9.25.1",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
