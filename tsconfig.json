{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "jsx": "react-jsx",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "skipLibCheck": true,
    "target": "ES2022"
  },
  "include": [
    "apps/**/*.js",
    "tests/**/*.js",
    "tests/**/*.mjs"
  ]
}
